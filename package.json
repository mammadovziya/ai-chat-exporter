{
  "name": "ai-chat-exporter",
  "version": "1.1.15",
  "private": true,
  "type": "module",
  "description": "A privacy-first browser extension for exporting Claude, ChatGPT, Gemini, and Grok chats to PDF, Markdown, Text, JSON, CSV, and PNG.",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "release": "npm run check && npm run package",
    "test": "node scripts/smoke-test.mjs",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "ai-chat-exporter",
    "browser-extension",
    "chrome-extension",
    "firefox-extension",
    "manifest-v3",
    "claude",
    "claude-export",
    "chatgpt",
    "chatgpt-export",
    "gemini",
    "gemini-export",
    "grok",
    "grok-export",
    "export",
    "chat-export",
    "conversation-export",
    "ai-chat-backup",
    "markdown",
    "markdown-export",
    "pdf",
    "pdf-export",
    "json-export",
    "csv-export",
    "png-export",
    "privacy",
    "privacy-first",
    "local-first",
    "open-source"
  ]
}
